enum OrderStatus {
  AWAITING_PAYMENT
  PAID
  CANCELLED
  FULFILLED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Product {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  description  String?
  line         String
  category     String
  priceCents   Int      @map("price_cents")
  currency     String   @default("brl")
  stock        Int      @default(0)
  active       Boolean  @default(true)
  imageUrl     String?  @map("image_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  orderItems OrderItem[]

  @@map("products")
}

model Order {
  id              String      @id @default(uuid())
  status          OrderStatus @default(AWAITING_PAYMENT)
  customerEmail   String      @map("customer_email")
  customerName    String?     @map("customer_name")
  userId          String?     @map("user_id")
  shippingJson    Json        @map("shipping_json")
  subtotalCents   Int         @map("subtotal_cents")
  shippingCents   Int         @map("shipping_cents")
  totalCents      Int         @map("total_cents")
  currency        String      @default("brl")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  items    OrderItem[]
  payments Payment[]

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id                  String @id @default(uuid())
  orderId             String @map("order_id")
  productId           String @map("product_id")
  productNameSnapshot String @map("product_name_snapshot")
  unitPriceCents      Int    @map("unit_price_cents")
  quantity            Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Payment {
  id                        String        @id @default(uuid())
  orderId                   String        @map("order_id")
  provider                  String
  providerCheckoutSessionId String?       @unique @map("provider_checkout_session_id")
  status                    PaymentStatus @default(PENDING)
  amountCents               Int           @map("amount_cents")
  currency                  String        @default("brl")
  createdAt                 DateTime      @default(now()) @map("created_at")
  updatedAt                 DateTime      @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

model ProcessedWebhookEvent {
  id         String   @id
  provider   String
  receivedAt DateTime @default(now()) @map("received_at")

  @@map("processed_webhook_events")
}
