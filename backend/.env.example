# Server
PORT=4500
NODE_VERSION="22.17.1"

# Database

# DATABASE_URL="postgresql://root:root@db:5432/auth_example_db" # docker
DATABASE_URL="postgresql://root:root@localhost:5432/rcastro_store_db"

# Authentication
JWT_SECRET="secret-example"
ALLOWED_ORIGINS="http://localhost:3000" # comma separated list of allowed origins

# Atrás de nginx / load balancer (X-Forwarded-For), use 1 para rate limit e IP corretos
TRUST_PROXY="0"

# AWS (for email sending)
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# APP CONFIGS
APP_NAME="Auth Example"
APP_DOMAIN="example.com.br"
APP_EMAIL="info@example.com.br"

# Email
EMAIL_FROM="Auth Example<info@example.com.br>"

# Pagamentos (Stripe — implementação via IPaymentGateway)
PAYMENT_PROVIDER="stripe"
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# URL de sucesso deve conter o placeholder exigido pelo Stripe Checkout:
CHECKOUT_SUCCESS_URL="http://localhost:3000/checkout/success?session_id={CHECKOUT_SESSION_ID}"
CHECKOUT_CANCEL_URL="http://localhost:3000/checkout"
